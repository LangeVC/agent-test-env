# Environment Configuration
# Copy to .env and adjust as needed

# Docker Compose project name
COMPOSE_PROJECT_NAME=agent-test-env

# Port mappings (avoid collisions with other services)
OPENCODE_PORT=8080
CLAUDE_CODE_PORT=8081
CODEX_CLI_PORT=8082
GEMINI_CLI_PORT=8083
CONTINUE_PORT=8084

# Test fixtures path
FIXTURES_PATH=./fixtures

